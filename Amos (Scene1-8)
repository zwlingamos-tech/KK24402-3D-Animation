void getPath_MainStop(float p, float stopZ, float& x, float& z, float& rotY) {
    x = -35.0f;
    rotY = 0.0f;
    z = 50.0f - p;
    if (z < stopZ) z = stopZ;
}

void getPath3_StraightDown(float p, float& x, float& z, float& rotY) {
    x = 30.0f; z = -600.0f + p; rotY = 180.0f;
}

void getPath4_RightToMain(float p, float& x, float& z, float& rotY) {
  
    if (p < 0) {
        x = 80.0f - p;
        z = -640.0f;
        rotY = 90.0f;
    }

    else if (p < 50.0f * PI / 2.0f) {
        float t = p / 50.0f;
        x = 80.0f - 50.0f * sinf(t);
        z = -590.0f - 50.0f * cosf(t);
        rotY = 90.0f + t * 180.0f / PI;
    }

    else {
        x = 30.0f;
        z = -590.0f + (p - 50.0f * PI / 2.0f);
        rotY = 180.0f;
    }
}

void drawSky() {
