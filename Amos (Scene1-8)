    glScalef(3.6f, 0.05f, 2.4f);
    glutSolidCube(1.0);
    glPopMatrix();

    // Fan face
    glPushMatrix();
    glTranslatef(-0.5f, 0.4f, -2.01f);
    glRotatef(-90.0f, 1.0f, 0.0f, 0.0f);

    GLfloat holeColor[] = { 0.02f, 0.02f, 0.02f, 1.0f };
    glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, holeColor);
    drawFlatCircle(1.5f, 20);

    GLfloat hubColor[] = { 0.4f, 0.4f, 0.45f, 1.0f };
    glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, hubColor);
    glTranslatef(0.0f, 0.01f, 0.0f);
    drawFlatCircle(0.4f, 12);

    glDisable(GL_LIGHTING);
    glColor3f(0.5f, 0.5f, 0.55f);
    glLineWidth(2.0f);

    glPushMatrix();
    glRotatef(time * 0.2f, 0.0f, 1.0f, 0.0f); // Spinning fan blades
    glBegin(GL_LINES);
    for (int i = 0; i < 8; i++) {
        float angle = i * (PI / 4.0f);
        glVertex3f(0.0f, 0.02f, 0.0f);
        glVertex3f(1.5f * cosf(angle), 0.02f, 1.5f * sinf(angle));
    }
    for (float r = 0.6f; r <= 1.2f; r += 0.3f) {
        for (int i = 0; i < 20; i++) {
            float a1 = i * (2.0f * PI / 20.0f);
            float a2 = (i + 1) * (2.0f * PI / 20.0f);
            glVertex3f(r * cosf(a1), 0.02f, r * sinf(a1));
            glVertex3f(r * cosf(a2), 0.02f, r * sinf(a2));
        }
    }
    glEnd();
    glPopMatrix();

    glLineWidth(1.0f);
    glEnable(GL_LIGHTING);
    glPopMatrix();
    glPopMatrix();
}

