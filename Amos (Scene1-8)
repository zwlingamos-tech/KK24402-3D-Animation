    // Top Signboard (Neon Accent Color)
    GLfloat signColor[] = { 1.0f, 0.3f, 0.1f, 1.0f };
    glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, signColor);
    glMaterialfv(GL_FRONT, GL_EMISSION, signColor);
    glPushMatrix();
    glTranslatef(faceX, topY + 8.0f, zPos);      
    glScalef(1.0f, 10.0f, 26.0f);               
    glutSolidCube(1.0);
    glPopMatrix();
    glMaterialfv(GL_FRONT, GL_EMISSION, noGlow);
}

// --- HORIZONTAL T-JUNCTION BUILDINGS (Windows face Z-Axis) ---
void drawHorizontalBuilding(float xPos, float zPos, float height, bool faceSouth) {
    float groundY = -90.0f;
    float topY = groundY + height;

    glPushMatrix();
    glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, bldgColor);
    glPushMatrix();
    float centerY = groundY + (height / 2.0f);
    glTranslatef(xPos, centerY, zPos);
    glScalef(30.0f, height, 20.0f); 
    glutSolidCube(1.0);
