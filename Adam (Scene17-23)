        float targetLookX = heliX;
        float targetLookY = targetHeight + 0.5f; // Point camera directly at gunner center
        float targetLookZ = heliZ - 1.0f;

        // Dynamic Camera Calculation
        camX = startCamX + (targetCamX - startCamX) * progress;
        camY = startCamY + (targetCamY - startCamY) * progress;
