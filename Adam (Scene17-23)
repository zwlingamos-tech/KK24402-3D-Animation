    // 1. MAIN BODY
    glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, metalDark);
    glPushMatrix();
        // Main structural mechanics box: width=0.6, height=0.6, depth=1.6
        glScalef(0.6f, 0.6f, 1.6f);
        glutSolidCube(1.0f);
