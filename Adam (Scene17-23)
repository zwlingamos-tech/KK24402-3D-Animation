void drawNeonText(const char* text) {
    glPushMatrix();
    glLineWidth(4.0f); // Bold glowing lines
    for (const char* c = text; *c != '\0'; c++) {
        glutStrokeCharacter(GLUT_STROKE_ROMAN, *c);
    }
    glLineWidth(1.0f);
    glPopMatrix();
}

void drawFlatCircle(float radius, int segments) {
    glBegin(GL_POLYGON);
    for (int i = 0; i < segments; i++) {
        float theta = 2.0f * PI * float(i) / float(segments);
        glVertex3f(radius * cosf(theta), 0.0f, radius * sinf(theta));
    }
    glEnd();
}

void drawSideBuilding(float xPos, float zPos, float height) {
    float groundY = -90.0f;
    float topY = groundY + height;

    glPushMatrix();
        glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, bldgColor);
        glPushMatrix();
            float centerY = groundY + (height / 2.0f);
            glTranslatef(xPos, centerY, zPos);
            glScalef(20.0f, height, 30.0f);
            glutSolidCube(1.0);
        glPopMatrix();

        glPushMatrix();
            glMaterialfv(GL_FRONT, GL_AMBIENT_AND_DIFFUSE, sideRoofCap);
            glTranslatef(xPos, topY + 0.5f, zPos);
            glScalef(21.0f, 2.0f, 31.0f);
            glutSolidCube(1.0);
        glPopMatrix();

        glMaterialfv(GL_FRONT, GL_EMISSION, windowGlow);
        float faceX = (xPos < 0) ? xPos + 10.1f : xPos - 10.1f;
        for (float wy = topY - 15.0f; wy > -60.0f; wy -= 10.0f) {
            for (float wz = zPos - 8.0f; wz <= zPos + 8.0f; wz += 8.0f) {
                glPushMatrix();
                    glTranslatef(faceX, wy, wz);
                    glScalef(0.5f, 3.5f, 3.0f);
                    glutSolidCube(1.0);
                glPopMatrix();
            }
        }
        glMaterialfv(GL_FRONT, GL_EMISSION, clear);
    glPopMatrix();
}

void drawHelipad(float x, float z) {
    glPushMatrix();
        glTranslatef(15.0f, 51.6f, 13.0f);
        glDisable(GL_LIGHTING);

        glColor3fv(bldgColor);
        drawFlatCircle(13.0f, 32);

        glTranslatef(0.0f, 0.1f, 0.0f);
        glColor3f(0.4f, 0.4f, 0.4f);
        drawFlatCircle(10.0f, 32);

        glTranslatef(0.0f, 0.1f, 0.0f);
        glColor3f(0.9f, 0.9f, 0.9f);
        glLineWidth(5.0f);
        glBegin(GL_LINES);
