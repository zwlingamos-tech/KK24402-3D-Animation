    }

    if (elapsedTime >= 11000 && elapsedTime < 14000) { // Scene 5: Run and Jump
       // 1. Animation and Camera Setting
       // Calculate scene time
       float sceneTime = elapsedTime - 11000.0f;

       // Normalize time into a 0.0f to 1.0f progress slider over a 3-second duration
       float progress = sceneTime / 3000.0f;
       if (progress > 1.0f) progress = 1.0f; // Max

       // Define Start Positions
