    if (elapsedTime >= 2500 && elapsedTime < 5000 ) { // Scene 2: Gunner Close-Up
        // 1. Camera Setting
        // Calculate scene time
        float sceneTime = elapsedTime - 2500.0f;

        // Normalize time into a 0.0f to 1.0f progress slider over a 1.7-second duration
