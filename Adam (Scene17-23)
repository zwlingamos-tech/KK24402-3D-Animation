        // 5. Black Screen Fade-In Sequence
        float t = sceneTime / 1000.0f; // Within 1 second
        if (t > 1.0f) t = 1.0f; // Max
        globalFadeAlpha = 1.0f - t;
        drawFadeOverlay(globalFadeAlpha);

    }

    drawHelipadScene(elapsedTime); // Draw Scene

    glFlush();
    glutSwapBuffers();
