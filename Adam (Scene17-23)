           glRotatef(-12.0f, 0.0f, 0.0f, 1.0f);
           glRotatef(-23.0f, 1.0f, 0.0f, 0.0f);
           glRotatef(23.0f, 0.0f, 1.0f, 0.0f);
           drawGunner(0.0f, 180.0f, 0.0f, 2); // Draw gunner strecthing out arm
       glPopMatrix();
    }

    if (elapsedTime >= 14000 && elapsedTime < 18000) { // Scene 6: The Getaway
        // 1. Animation and Camera Setting
        // Calculate scene time
        float sceneTime = elapsedTime - 14000.0f;

        // Helicopter Animation
        float t = sceneTime / 1000.0f; // Animation done in 1 second
        heliSway = -30.0f * expf(-4.0f * t) * sinf(t * 3.14159f * 2.0f); // Adding impact sway

        if (sceneTime >= 800) { // Starts after 0.8 second
            float t = (sceneTime - 800.0f) / 500.0f; // Animation done in 0.5 second
            if (t > 1.0f) t = 1.0f; // Max
            noseDive = 20.0f * t; // Add nose dive

            heliZ = (sceneTime - 800.0f) * 0.03f + heliZ; // Helicopter moves forward
            heliY = (sceneTime - 800.0f) * 0.01f + heliY; // Helicopter moves up
        }

        // Apply bobbing for helicopter
        heliY = heliY + bobbingOffset;

        // Normalize time into a 0.0f to 1.0f progress slider over a 3.2-second duration
        float progress;
        if (sceneTime < 800) progress = 0.0f;
        else progress = (sceneTime - 800) / 3200.0f; // Progress starts after 0.8 second

