                    glRotatef(90.0f, 0.0f, 1.0f, 0.0f); // Rotated to the left
                    drawMinigun(elapsedTime);
                glPopMatrix();
        glPopMatrix();
    }

    if (elapsedTime >= 5000 && elapsedTime < 8000) { // Scene 3: Gunner Shooting
        // 1. Timing and Camera Setting
        // Calculate scene time
        float sceneTime = elapsedTime - 5000.0f;

        // Camera Position and Target
        lookX = heliX; lookY = targetHeight + 1.5f; lookZ = heliZ - 1.0f; // Look at gunner face
        camX = heliX + 1.0f; camY = targetHeight + 1.0f; camZ = heliZ + 0.5f;

        // Timed Lighting and Shake
        if (sceneTime < 2300.0f) {
            bool lightIsOn = ((int)(elapsedTime * 0.04f) % 2) == 0; // Calculate when light is on

            if (lightIsOn) {
                // Push a temporary bright amber/orange point light right in front of the gun barrel
                GLfloat flashColor[] = { 1.0f, 0.6f, 0.1f, 1.0f }; // Muzzle flash orange
                GLfloat flashPos[] = { heliX + 8.0f, targetHeight, heliZ, 1.0f };

                glEnable(GL_LIGHT1); // Ensure GL_LIGHT1 is enabled
                glLightfv(GL_LIGHT1, GL_DIFFUSE, flashColor);
                glLightfv(GL_LIGHT1, GL_POSITION, flashPos);
            }
            else {
                glDisable(GL_LIGHT1); // Kill the light instantly on alternating frames
            }
            // Camera Shake
            float shakeIntensity = 0.01f; // Adjust shake strength
            float shakeOffsetX = sinf(elapsedTime * 0.05f) * shakeIntensity;
            float shakeOffsetY = cosf(elapsedTime * 0.06f) * shakeIntensity;
            float shakeOffsetZ = sinf(elapsedTime * 0.07f) * shakeIntensity;

            // Apply offsets to both where the camera is and what it's looking at
            camX += shakeOffsetX;      lookX += shakeOffsetX;
            camY += shakeOffsetY;      lookY += shakeOffsetY;
            camZ += shakeOffsetZ;      lookZ += shakeOffsetZ;

            if (freeCamMode) { // Free Cam Mode
                gluLookAt(freeCamX, freeCamY, freeCamZ, freeLookX, freeLookY, freeLookZ, 0.0f, 1.0f, 0.0f);
            }
            else { // Scripted Camera
                gluLookAt(camX, camY, camZ, lookX, lookY, lookZ, upX, upY, upZ);
