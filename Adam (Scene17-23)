void drawFadeOverlay(float alpha) {
    // 1. Change projection matrix to 2D Orthographic
    glMatrixMode(GL_PROJECTION);
    glPushMatrix();
        glLoadIdentity();
        gluOrtho2D(0.0, 1.0, 0.0, 1.0); // Create a simple 0 to 1 coordinate flat canvas

        glMatrixMode(GL_MODELVIEW);
        glPushMatrix();

            glLoadIdentity();
            // 2. Disable Depth testing and lighting
            glDisable(GL_LIGHTING);
            glDisable(GL_DEPTH_TEST);
            glEnable(GL_BLEND);

            // 3. Draw a solid black square with transparency value
            glColor4f(0.0f, 0.0f, 0.0f, alpha);
            glBegin(GL_QUADS);
                glVertex2f(0.0f, 0.0f);
                glVertex2f(1.0f, 0.0f);
                glVertex2f(1.0f, 1.0f);
                glVertex2f(0.0f, 1.0f);
            glEnd();

            // 4. Clean up state changes and restore original 3D perspective settings
            glEnable(GL_DEPTH_TEST);
            glEnable(GL_LIGHTING);

        glPopMatrix();
        glMatrixMode(GL_PROJECTION);
    glPopMatrix();
    glMatrixMode(GL_MODELVIEW);
}

// MASTER DISPLAY
void display() {
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);
    glLoadIdentity();

    // Operative Starting Position
    float posX = -9.5f, posY = 53.5f, posZ = 10.0f;
    float pitch = 0.0f, yaw = 90.0f, roll = 0.0f;

    // Camera Variables
    float camX = 0.0f, camY = 58.0f, camZ = 30.0f;
    float lookX = 0.0f, lookY = 0.0f, lookZ = 0.0f;
    float upX = 0.0f, upY = 1.0f, upZ = 0.0f; // Y-axis is up

    // Helicopter Positioning
    float startHeight = 0.0f;   // Starting altitude
    float targetHeight = 58.0f;  // Perfect final hovering height
    float brakeFactor = 0.0015f; // Adjust this to control deceleration speed
    float heliX = -40.0f, heliY = targetHeight, heliZ = 10.0f; // Position
    float bobbingOffset = sinf(elapsedTime * 0.002f) * 0.4f; // Adjust 0.002f for speed of bobbing, adjust 0.4f for the height gap
    float gentleRoll = sinf(elapsedTime * 0.0015f) * 1.5f; // Slight side-to-side rock (1.5 degrees)
    float gentlePitch = cosf(elapsedTime * 0.0018f) * 1.0f; // Slight nose-up or nose-down dip
    float heliSway = 0.0f; // Swaying Impact
    float noseDive = 0.0f; // Rotation when moving
    
    drawSky(); // Drawing The Sky

    if (elapsedTime >= 0 && elapsedTime < 2500) { // Scene 1: Helicopter Arrival
        // 1. Calculation and Camera Setting
        // Helicopter Animation
        float heliY = (targetHeight - startHeight) * (1.0f - expf(-brakeFactor * elapsedTime)) + startHeight; // Calculation

        // Camera Position and Target
        lookX = heliX; lookY = heliY; lookZ = heliZ; // Look at helicopter
        camX = posX + 10.0f; camY = posY + 5; camZ = posZ; // Slightly behind operative

        // Camera Shake
        float shakeIntensity = 0.1f; // Adjust shake strength
        float shakeOffsetX = sinf(elapsedTime * 0.05f) * shakeIntensity;
        float shakeOffsetY = cosf(elapsedTime * 0.06f) * shakeIntensity;
        float shakeOffsetZ = sinf(elapsedTime * 0.07f) * shakeIntensity;

        // Apply offsets to both where the camera is and what it's looking at
        camX += shakeOffsetX;      lookX += shakeOffsetX;
        camY += shakeOffsetY;      lookY += shakeOffsetY;
        camZ += shakeOffsetZ;      lookZ += shakeOffsetZ;

        if (freeCamMode) { // Free Cam Mode
            gluLookAt(freeCamX, freeCamY, freeCamZ, freeLookX, freeLookY, freeLookZ, 0.0f, 1.0f, 0.0f);
        }
        else { // Scripted Camera
