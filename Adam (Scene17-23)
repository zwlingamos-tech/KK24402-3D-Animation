                drawGunner(0.0f, 180.0f, 0.0f, 2); // Draw gunner strecthing out arm
            glPopMatrix();
        glPopMatrix();

        // 4. Black Screen Fade-Out Sequence
        if (sceneTime > 3500) {
            float t = (sceneTime - 3500) / 500.0f; // Within 0.5 second
            if (t > 1.0f) t = 1.0f; // Max
            globalFadeAlpha = t;
            drawFadeOverlay(globalFadeAlpha);
        }
    }

    if (elapsedTime >= 18000) { // Scene 7: The End
        // 1. Animation and Camera Setting
        // Calculate scene time
        float sceneTime = elapsedTime - 18000.0f;

        // Camera Position and Target
        heliY = heliY + 1000.0f;
        lookX = heliX + 2.0f; lookY = heliY; lookZ = heliZ - 2.0f;
